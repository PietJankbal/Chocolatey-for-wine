+ */
+
+
+#include "initguid.h"
+
+#define COBJMACROS
+
+#include <stdarg.h>
+
+#include "windef.h"
+#include "winbase.h"
+#include "winuser.h"
+#include "ole2.h"
+#include "rpcproxy.h"
+#include "eventsys.h"
+
+#include "wine/debug.h"
+#include "es_private.h"
+
+
+
+WINE_DEFAULT_DEBUG_CHANNEL(es);
+
+typedef HRESULT (*fnCreateInstance)( LPVOID *ppObj );
+
+typedef struct _escf
+{
+    IClassFactory IClassFactory_iface;
+    fnCreateInstance pfnCreateInstance;
+} escf;
+
+static inline escf *impl_from_IClassFactory( IClassFactory *iface )
+{
+    return CONTAINING_RECORD(iface, escf, IClassFactory_iface);
+}
+
+static HRESULT WINAPI escf_QueryInterface( IClassFactory *iface, REFIID riid, LPVOID *ppobj )
+{
+    if (IsEqualGUID(riid, &IID_IUnknown) ||
+        IsEqualGUID(riid, &IID_IClassFactory))
+    {
+        IClassFactory_AddRef( iface );
+        *ppobj = iface;
+        return S_OK;
+    }
+    FIXME("interface %s not implemented\n", debugstr_guid(riid));
+    return E_NOINTERFACE;
+}
+
+static ULONG WINAPI escf_AddRef( IClassFactory *iface )
+{
+    return 2;
+}
+
+static ULONG WINAPI escf_Release( IClassFactory *iface )
+{
+    return 1;
+}
+
+static HRESULT WINAPI escf_CreateInstance( IClassFactory *iface, LPUNKNOWN pOuter,
+                                           REFIID riid, LPVOID *ppobj )
+{
+    escf *This = impl_from_IClassFactory( iface );
+    HRESULT r;
+    IUnknown *punk;
+
+    TRACE("%p %s %p\n", pOuter, debugstr_guid(riid), ppobj);
+
+    *ppobj = NULL;
+
+    if (pOuter)
+        return CLASS_E_NOAGGREGATION;
+
+    r = This->pfnCreateInstance( (LPVOID *)&punk );
+    if (FAILED(r))
+        return r;
+
+    r = IUnknown_QueryInterface( punk, riid, ppobj );
+    IUnknown_Release( punk );
+    return r;
+}
+
+static HRESULT WINAPI escf_LockServer( IClassFactory *iface, BOOL dolock )
+{
+    FIXME("(%p)->(%d)\n", iface, dolock);
+    return S_OK;
+}
+
+static const struct IClassFactoryVtbl escf_vtbl =
+{
+    escf_QueryInterface,
+    escf_AddRef,
+    escf_Release,
+    escf_CreateInstance,
+    escf_LockServer
+};
+
+static escf subscriptioncf = { { &escf_vtbl }, EventSubscription_create };
+static escf systemcf = { { &escf_vtbl }, EventSystem_create };
+
+HRESULT WINAPI DllGetClassObject( REFCLSID rclsid, REFIID iid, LPVOID *ppv )
+{
+    IClassFactory *cf = NULL;
+
+    TRACE("%s %s %p\n", debugstr_guid(rclsid), debugstr_guid(iid), ppv);
+
+    if (IsEqualGUID( rclsid, &CLSID_CEventSubscription ))
+    {
+       cf = &subscriptioncf.IClassFactory_iface;
+    }
+    else if (IsEqualGUID( rclsid, &CLSID_CEventSystem ))
+    {
+       cf = &systemcf.IClassFactory_iface;
+    }
+    if (!cf) return CLASS_E_CLASSNOTAVAILABLE;
+    return IClassFactory_QueryInterface( cf, iid, ppv );
+}
